{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guild.dev/conformance/adapter-profile.schema.json",
  "title": "Guild Adapter Conformance Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "adapter_name",
    "package",
    "profile",
    "orchestrator",
    "capabilities",
    "required_checks",
    "badge"
  ],
  "properties": {
    "schema_version": {
      "const": "v1alpha1"
    },
    "adapter_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "adapter_name": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "enum": ["adapter-alpha"]
    },
    "orchestrator": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "taskpack.create",
          "mandate.next",
          "mandate.close",
          "mandate.verify",
          "context.compile",
          "preflight.check",
          "approval.request",
          "dri.assign",
          "artifact.publish",
          "handoff.create",
          "replay.export",
          "state.patch",
          "transport.map"
        ]
      },
      "uniqueItems": true
    },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "schemas.closed",
          "taskpack.valid",
          "context.bounded",
          "preflight.policy",
          "approval.explicit",
          "handoff.structured",
          "dri.single_owner",
          "artifact.provenance",
          "replay.compatible",
          "tests.local"
        ]
      },
      "uniqueItems": true
    },
    "badge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
