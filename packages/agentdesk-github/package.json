{
  "name": "@lucid-fdn/agentdesk-github",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit && tsx --test tests/*.test.ts",
    "prepack": "npm run build",
    "test": "tsx --test tests/*.test.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lucid-fdn/agentdesk-core": "workspace:*"
  },
  "devDependencies": {
    "@guild/client": "workspace:*",
    "@types/node": "^22.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
