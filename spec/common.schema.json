{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guild.dev/spec/common.schema.json",
  "title": "Guild Common Types",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._/-]{0,63}$"
      },
      "uniqueItems": true
    },
    "actorRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_type",
        "display_name"
      ],
      "properties": {
        "actor_id": {
          "$ref": "#/$defs/uuid"
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "service"
          ]
        },
        "display_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "orchestrator": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "endpoint": {
          "$ref": "#/$defs/uri"
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "kind",
        "uri"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/uuid"
        },
        "kind": {
          "type": "string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "metricDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "before",
        "after",
        "direction"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "before": {
          "type": "number"
        },
        "after": {
          "type": "number"
        },
        "direction": {
          "type": "string",
          "enum": [
            "higher_is_better",
            "lower_is_better"
          ]
        },
        "unit": {
          "type": "string"
        }
      }
    }
  }
}

