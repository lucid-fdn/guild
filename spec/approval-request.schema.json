{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guild.dev/spec/approval-request.schema.json",
  "title": "Approval Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_id", "taskpack_id", "requested_by", "reason", "required_approvals", "status", "created_at"],
  "properties": {
    "schema_version": { "const": "v1alpha1" },
    "approval_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "taskpack_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "policy_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "requested_by": { "$ref": "common.schema.json#/$defs/actorRef" },
    "reason": { "type": "string", "minLength": 1 },
    "required_approvals": { "type": "integer", "minimum": 1 },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actor", "decision", "decided_at"],
        "properties": {
          "actor": { "$ref": "common.schema.json#/$defs/actorRef" },
          "decision": { "type": "string", "enum": ["approved", "rejected"] },
          "reason": { "type": "string" },
          "decided_at": { "$ref": "common.schema.json#/$defs/timestamp" }
        }
      }
    },
    "status": { "type": "string", "enum": ["pending", "approved", "rejected", "canceled"] },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "decided_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
