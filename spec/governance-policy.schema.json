{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guild.dev/spec/governance-policy.schema.json",
  "title": "Governance Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "institution_id", "name", "applies_to", "rules", "created_by", "created_at"],
  "properties": {
    "schema_version": { "const": "v1alpha1" },
    "policy_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "institution_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "description": { "type": "string" },
    "applies_to": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["taskpack", "artifact", "promotion_record", "commons_entry"] }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "effect", "condition"],
        "properties": {
          "rule_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,31}$" },
          "effect": { "type": "string", "enum": ["allow", "deny", "require_approval"] },
          "condition": { "type": "string", "minLength": 1 },
          "requires": { "type": "array", "items": { "type": "string" } },
          "min_approvals": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "created_by": { "$ref": "common.schema.json#/$defs/actorRef" },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
